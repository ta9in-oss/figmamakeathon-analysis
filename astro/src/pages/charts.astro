---
import Layout from "../layouts/Layout.astro";
import TimingHistogram from "../components/charts/TimingHistogram";
import EngagementScatter from "../components/charts/EngagementScatter";
import ComparisonBoxplots from "../components/charts/ComparisonBoxplots";
import EngagementDistribution from "../components/charts/EngagementDistribution";
import WinnerTimeline from "../components/charts/WinnerTimeline";
import VideoVsSocialChart from "../components/charts/VideoVsSocialChart";
import StaffPresenceChart from "../components/charts/StaffPresenceChart";
---

<Layout title="Data Analysis">
  <section class="mx-auto max-w-4xl px-6 py-16">

    <header class="mb-16">
      <p class="text-xs font-semibold uppercase tracking-widest text-muted-foreground mb-3">Interactive Analysis</p>
      <h1 class="text-4xl font-extrabold tracking-tight mb-4 leading-tight">You Put In the Work.<br/>Here's What the Data Shows.</h1>
      <p class="text-muted-foreground text-lg max-w-2xl">
        4,212 posts. 3,303 creators. Three editions with $300K in prizes.
        We scraped every submission and ran the numbers so you can see exactly what separated the winners from everyone else.
      </p>
    </header>

    <div class="space-y-24">

      <!-- Q1: OVERVIEW -->
      <div id="q1">
        <div class="mb-8">
          <span class="text-xs font-semibold uppercase tracking-widest" style="color:#BA7517">The Playing Field</span>
          <h2 class="text-2xl font-bold mt-2">How big was this, really?</h2>
          <p class="text-muted-foreground mt-2 max-w-2xl">
            Most people have no idea how many others they were up against. Before you ask why you didn't win,
            start here: the field was enormous and the community was real.
          </p>
        </div>

        <div class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-8">
          <div class="rounded-xl border border-border p-5 bg-card">
            <div class="text-3xl font-bold mb-1" style="color:#BA7517">4,212</div>
            <div class="text-sm text-muted-foreground">Posts submitted across all editions</div>
          </div>
          <div class="rounded-xl border border-border p-5 bg-card">
            <div class="text-3xl font-bold mb-1" style="color:#BA7517">3,303</div>
            <div class="text-sm text-muted-foreground">Unique creators who showed up</div>
          </div>
          <div class="rounded-xl border border-border p-5 bg-card">
            <div class="text-3xl font-bold mb-1" style="color:#1D9E75">1 in 155</div>
            <div class="text-sm text-muted-foreground">Odds of winning any prize</div>
          </div>
          <div class="rounded-xl border border-border p-5 bg-card">
            <div class="text-3xl font-bold mb-1" style="color:#1D9E75">$300K</div>
            <div class="text-sm text-muted-foreground">Total prize pool across 3 editions</div>
          </div>
        </div>

        <div class="grid grid-cols-3 gap-4">
          <div class="rounded-xl border border-border p-5 bg-card">
            <div class="flex items-center gap-2 mb-3">
              <span class="w-3 h-3 rounded-full inline-block" style="background:#3B82F6"></span>
              <span class="text-sm font-semibold">Sep 2025 (8 days)</span>
            </div>
            <div class="space-y-1 text-sm text-muted-foreground">
              <div>1,771 posts from 1,406 creators</div>
              <div>Winners averaged <strong class="text-foreground">69 likes</strong></div>
              <div>Non-winners averaged <strong class="text-foreground">4 likes</strong></div>
            </div>
          </div>
          <div class="rounded-xl border border-border p-5 bg-card">
            <div class="flex items-center gap-2 mb-3">
              <span class="w-3 h-3 rounded-full inline-block" style="background:#BA7517"></span>
              <span class="text-sm font-semibold">Mar 2026 (44 days)</span>
            </div>
            <div class="space-y-1 text-sm text-muted-foreground">
              <div>1,495 posts from 1,239 creators</div>
              <div>Winners averaged <strong class="text-foreground">55 likes</strong></div>
              <div>Non-winners averaged <strong class="text-foreground">9 likes</strong></div>
            </div>
          </div>
          <div class="rounded-xl border border-border p-5 bg-card">
            <div class="flex items-center gap-2 mb-3">
              <span class="w-3 h-3 rounded-full inline-block" style="background:#8B5CF6"></span>
              <span class="text-sm font-semibold">Config 2026 (15 days)</span>
            </div>
            <div class="space-y-1 text-sm text-muted-foreground">
              <div>946 posts from 658 creators</div>
              <div>Winners averaged <strong class="text-foreground">47 likes</strong></div>
              <div>Non-winners averaged <strong class="text-foreground">9 likes</strong></div>
            </div>
          </div>
        </div>
      </div>

      <!-- Q2: WHAT EVERYBODY DID -->
      <div id="q2">
        <div class="mb-8">
          <span class="text-xs font-semibold uppercase tracking-widest" style="color:#BA7517">The Baseline</span>
          <h2 class="text-2xl font-bold mt-2">Getting fewer than 10 likes? So did most people.</h2>
          <p class="text-muted-foreground mt-2 max-w-2xl">
            Before you judge your own submission by its like count, see what everyone else got.
            Engagement was heavily skewed. A handful of posts took most of the attention.
            The chart below shows what percentage of posts fell into each likes tier, per edition.
          </p>
        </div>

        <div class="rounded-xl border border-border p-6 bg-card mb-6">
          <p class="text-xs text-muted-foreground mb-5">
            Color = edition.
            <span class="inline-flex items-center gap-1 mx-1"><span class="w-2 h-2 rounded-full inline-block" style="background:#3B82F6"></span>Sep 2025</span>
            <span class="inline-flex items-center gap-1 mx-1"><span class="w-2 h-2 rounded-full inline-block" style="background:#BA7517"></span>Mar 2026</span>
            <span class="inline-flex items-center gap-1 mx-1"><span class="w-2 h-2 rounded-full inline-block" style="background:#8B5CF6"></span>Config 2026</span>
          </p>
          <EngagementDistribution client:load />
        </div>

        <div class="grid grid-cols-3 gap-4">
          <div class="rounded-xl border border-border p-4 bg-card">
            <div class="text-sm font-semibold mb-2">Sep 2025 (8-day window)</div>
            <div class="space-y-1 text-sm text-muted-foreground">
              <div><strong class="text-foreground">36%</strong> of posts got zero likes</div>
              <div><strong class="text-foreground">49%</strong> got 1 to 5 likes</div>
              <div>Only <strong class="text-foreground">3%</strong> got more than 50</div>
              <div class="pt-1 text-xs">Short window = less time to spread</div>
            </div>
          </div>
          <div class="rounded-xl border border-border p-4 bg-card">
            <div class="text-sm font-semibold mb-2">Mar 2026 (44-day window)</div>
            <div class="space-y-1 text-sm text-muted-foreground">
              <div><strong class="text-foreground">2%</strong> got zero likes</div>
              <div><strong class="text-foreground">54%</strong> got 1 to 5 likes</div>
              <div><strong class="text-foreground">5%</strong> got more than 50</div>
              <div class="pt-1 text-xs">Longer window meant more community circulation</div>
            </div>
          </div>
          <div class="rounded-xl border border-border p-4 bg-card">
            <div class="text-sm font-semibold mb-2">Config 2026 (15-day window)</div>
            <div class="space-y-1 text-sm text-muted-foreground">
              <div><strong class="text-foreground">4%</strong> got zero likes</div>
              <div><strong class="text-foreground">65%</strong> got 1 to 5 likes</div>
              <div><strong class="text-foreground">3%</strong> got more than 50</div>
              <div class="pt-1 text-xs">Most competitive distribution of the three</div>
            </div>
          </div>
        </div>
      </div>

      <!-- Q3: WHAT WINNERS DID -->
      <div id="q3">
        <div class="mb-8">
          <span class="text-xs font-semibold uppercase tracking-widest" style="color:#BA7517">The Gap</span>
          <h2 class="text-2xl font-bold mt-2">Winners didn't just build better. They posted differently.</h2>
          <p class="text-muted-foreground mt-2 max-w-2xl">
            Across all three editions, winning posts averaged <strong class="text-foreground">7.7 times more likes</strong> than non-winning posts.
            That gap isn't about luck. The scatter below shows every post in the contest window.
            <strong class="text-foreground">Green stars are winners.</strong> Gray dots are everyone else. Hover any point for details.
          </p>
        </div>

        <div class="rounded-xl border border-border p-6 bg-card mb-6">
          <p class="text-xs text-muted-foreground mb-1">
            <span class="inline-flex items-center gap-1 mr-3"><span class="w-2 h-2 rounded-full inline-block" style="background:#1D9E75"></span>Winners</span>
            <span class="inline-flex items-center gap-1"><span class="w-2 h-2 rounded-full inline-block" style="background:#888780"></span>Non-Winners</span>
          </p>
          <WinnerTimeline client:load />
        </div>

        <div class="rounded-xl border border-border p-6 bg-card mb-6">
          <h3 class="text-sm font-semibold mb-2">Did posting earlier give winners an edge?</h3>
          <p class="text-sm text-muted-foreground mb-4">
            In Sep 2025's 8-day sprint, winners posted at day 5.4 on average versus day 6.2 for non-winners.
            That half-day head start let engagement compound before the window closed.
            In longer editions (Mar 2026: 44 days, Config 2026: 15 days), timing was nearly identical between winners and non-winners.
            Early posting only matters when the window is short.
          </p>
          <TimingHistogram client:load />
        </div>

        <div class="rounded-xl border border-border p-5 bg-card">
          <div class="text-sm font-semibold mb-3">Winner quick facts</div>
          <div class="grid grid-cols-2 md:grid-cols-4 gap-4 text-sm text-muted-foreground">
            <div><strong class="text-foreground block text-lg font-bold" style="color:#1D9E75">54.4</strong>avg winner likes (cross-edition)</div>
            <div><strong class="text-foreground block text-lg font-bold" style="color:#1D9E75">7.1</strong>avg non-winner likes</div>
            <div><strong class="text-foreground block text-lg font-bold" style="color:#1D9E75">217</strong>Cara Ellis (Sep 2025 $50K) likes</div>
            <div><strong class="text-foreground block text-lg font-bold" style="color:#1D9E75">23</strong>Bene Brandhofer (Config $50K) likes</div>
          </div>
          <p class="text-xs text-muted-foreground mt-3">
            The wide range (217 vs 23) shows that high engagement correlates with winning, but is not a requirement.
            The Config 2026 grand prize went to the best interaction design, not the most-liked post.
          </p>
        </div>
      </div>

      <!-- Q4: VIDEO & SOCIAL -->
      <div id="q4">
        <div class="mb-8">
          <span class="text-xs font-semibold uppercase tracking-widest" style="color:#BA7517">The Format</span>
          <h2 class="text-2xl font-bold mt-2">Should you have posted a video? Almost certainly yes.</h2>
          <p class="text-muted-foreground mt-2 max-w-2xl">
            The single most consistent difference between winners and non-winners across all three editions
            was whether the post included a video demo. A working video proves the interaction is real.
            It reduces skepticism. It gets shared.
          </p>
        </div>

        <div class="rounded-xl border border-border p-6 bg-card mb-6">
          <p class="text-xs text-muted-foreground mb-5">
            <span class="inline-flex items-center gap-1 mr-3"><span class="w-2 h-2 rounded-sm inline-block" style="background:#1D9E75"></span>Winners with Video</span>
            <span class="inline-flex items-center gap-1"><span class="w-2 h-2 rounded-sm inline-block" style="background:#888780"></span>Non-Winners with Video</span>
          </p>
          <VideoVsSocialChart client:load />
        </div>

        <div class="grid grid-cols-3 gap-4 mb-6">
          <div class="rounded-xl border border-border p-4 bg-card">
            <div class="text-sm font-semibold mb-2">Sep 2025</div>
            <div class="space-y-1 text-sm text-muted-foreground">
              <div>Winners with video: <strong class="text-foreground">40%</strong></div>
              <div>Non-winners with video: <strong class="text-foreground">7.5%</strong></div>
              <div class="text-xs pt-1">5x more likely to win with a video</div>
            </div>
          </div>
          <div class="rounded-xl border border-border p-4 bg-card">
            <div class="text-sm font-semibold mb-2">Mar 2026</div>
            <div class="space-y-1 text-sm text-muted-foreground">
              <div>Winners with video: <strong class="text-foreground">90%</strong></div>
              <div>Non-winners with video: <strong class="text-foreground">56%</strong></div>
              <div class="text-xs pt-1">By March 2026, video was the norm</div>
            </div>
          </div>
          <div class="rounded-xl border border-border p-4 bg-card">
            <div class="text-sm font-semibold mb-2">Config 2026</div>
            <div class="space-y-1 text-sm text-muted-foreground">
              <div>Winners with video: <strong class="text-foreground">67%</strong></div>
              <div>Non-winners with video: <strong class="text-foreground">59%</strong></div>
              <div class="text-xs pt-1">Gap narrows when video is everywhere</div>
            </div>
          </div>
        </div>

        <div class="rounded-xl border border-border p-5 bg-card">
          <div class="text-sm font-semibold mb-3">Did cross-posting to X, LinkedIn, or Instagram matter?</div>
          <p class="text-sm text-muted-foreground mb-4">
            In Sep 2025 and Mar 2026, cross-posting made a small difference. By Config 2026, it jumped:
            winners averaged <strong class="text-foreground">1.2 social platforms</strong> versus
            <strong class="text-foreground">0.4</strong> for non-winners. That is not a coincidence.
            Config 2026 added a "Build In Public" award category that explicitly rewarded public
            documentation of your process across platforms. If you are entering the next contest,
            check whether a "Build In Public" category exists before deciding how much to share.
          </p>
          <div class="grid grid-cols-3 gap-4 text-sm">
            <div class="text-muted-foreground">
              Sep 2025: winners <strong class="text-foreground">0.2</strong> platforms, non-winners <strong class="text-foreground">0.1</strong>
            </div>
            <div class="text-muted-foreground">
              Mar 2026: winners <strong class="text-foreground">0.9</strong> platforms, non-winners <strong class="text-foreground">0.5</strong>
            </div>
            <div class="text-muted-foreground">
              Config 2026: winners <strong class="text-foreground">1.2</strong> platforms, non-winners <strong class="text-foreground">0.4</strong>
            </div>
          </div>
        </div>
      </div>

      <!-- Q5: JUDGES -->
      <div id="q5">
        <div class="mb-8">
          <span class="text-xs font-semibold uppercase tracking-widest" style="color:#BA7517">The Judging</span>
          <h2 class="text-2xl font-bold mt-2">Were the judges watching your posts? We checked.</h2>
          <p class="text-muted-foreground mt-2 max-w-2xl">
            One of the most common questions after not placing: did the judges even see my work?
            We loaded the full comment threads for three winner posts to find out.
          </p>
        </div>

        <div class="rounded-xl border border-amber-500/30 bg-amber-500/5 p-6 mb-6">
          <div class="text-base font-semibold mb-3">Finding: Zero judge comments on any winner post.</div>
          <p class="text-sm text-muted-foreground leading-relaxed mb-4">
            We checked three winner posts directly: Cara Ellis's Web Poetry (Sep 2025, $50K, 217 likes),
            Lee Black's Airwwave (March 2026, Boundary Pushing, 222 likes), and Bene Brandhofer's
            Visual Atlas (Config 2026, $50K Grand Prize, 23 likes).
            Not a single Contra staff member or judge commented on any of them before the winners were announced.
          </p>
          <p class="text-sm text-muted-foreground leading-relaxed">
            This means you cannot reverse-engineer who will win by watching for judge engagement.
            It also means the absence of a judge comment on your post tells you nothing.
            Judging happens entirely off-platform. The winners were selected based on project quality reviewed
            externally, not on how much attention their Contra posts received from the Contra team.
          </p>

          <div class="grid grid-cols-3 gap-3 mt-5 text-xs">
            <div class="rounded-lg border border-border p-3 bg-card">
              <div class="font-semibold text-foreground mb-1">Cara Ellis — Web Poetry</div>
              <div class="text-muted-foreground">217 likes, 20 community comments</div>
              <div class="mt-1 font-medium" style="color:#1D9E75">0 staff or judge comments</div>
            </div>
            <div class="rounded-lg border border-border p-3 bg-card">
              <div class="font-semibold text-foreground mb-1">Lee Black — Airwwave</div>
              <div class="text-muted-foreground">222 likes, 90 comments. Lee replied to 80%+ himself.</div>
              <div class="mt-1 font-medium" style="color:#1D9E75">0 staff or judge comments</div>
            </div>
            <div class="rounded-lg border border-border p-3 bg-card">
              <div class="font-semibold text-foreground mb-1">Bene Brandhofer — Visual Atlas</div>
              <div class="text-muted-foreground">23 likes, 8 community comments</div>
              <div class="mt-1 font-medium" style="color:#1D9E75">0 staff or judge comments</div>
            </div>
          </div>
        </div>

        <div class="rounded-xl border border-border p-6 bg-card mb-6">
          <h3 class="text-sm font-semibold mb-2">What did Contra staff actually post?</h3>
          <p class="text-sm text-muted-foreground mb-4">
            Staff posts were entirely broadcasts: kick-off announcements, judging criteria clarifications, and winner reveals.
            Gui Seiz's March 2026 winner reveal reached <strong class="text-foreground">91,802 impressions</strong>,
            making it the most-viewed post across all three editions. Staff posts generated conversation (comments, replies)
            but were not engagement with individual submissions.
          </p>
          <StaffPresenceChart client:load />
        </div>

        <div class="grid grid-cols-3 gap-4">
          <div class="rounded-xl border border-border p-4 bg-card text-sm">
            <div class="font-semibold mb-2">Sep 2025</div>
            <div class="text-muted-foreground">Galaxia Wu's kick-off post reached 47K+ impressions. Gui Seiz posted judge introductions. All staff posts were announcements.</div>
          </div>
          <div class="rounded-xl border border-border p-4 bg-card text-sm">
            <div class="font-semibold mb-2">Mar 2026</div>
            <div class="text-muted-foreground">Gui Seiz's winner reveal: 91,802 impressions. The community found out through Contra, not through individual post engagement.</div>
          </div>
          <div class="rounded-xl border border-border p-4 bg-card text-sm">
            <div class="font-semibold mb-2">Config 2026</div>
            <div class="text-muted-foreground">Jan Mráz posted three criteria and update posts (15K to 26K impressions each). Staff posts clustered on day 1 and after day 14.</div>
          </div>
        </div>
      </div>

      <!-- Q6: CRITERIA -->
      <div id="q6">
        <div class="mb-8">
          <span class="text-xs font-semibold uppercase tracking-widest" style="color:#BA7517">The Brief</span>
          <h2 class="text-2xl font-bold mt-2">Did winners actually read the judging criteria?</h2>
          <p class="text-muted-foreground mt-2 max-w-2xl">
            Each edition had published judging criteria. We looked at whether winner posts reflected those
            criteria in their language and project framing, and whether the criteria evolved between editions
            in ways that changed what it takes to win.
          </p>
        </div>

        <div class="rounded-xl border border-border p-6 bg-card mb-6">
          <h3 class="text-sm font-semibold mb-2">Engagement score vs posting day, across all editions</h3>
          <p class="text-sm text-muted-foreground mb-4">
            Green stars are winner posts. The cluster of high-engagement winners above the cloud
            shows that engagement and judging quality are correlated, but they are not the same thing.
            Several non-winners in the top-right (high engagement, late posting) did not place.
          </p>
          <EngagementScatter client:load />
        </div>

        <div class="grid grid-cols-3 gap-4 mb-6">
          <div class="rounded-xl border border-border p-5 bg-card text-sm">
            <div class="font-semibold mb-3">Sep 2025</div>
            <div class="space-y-2 text-muted-foreground">
              <div><strong class="text-foreground">Criteria:</strong> Novelty, interaction quality, use of Figma's prototyping tools</div>
              <div><strong class="text-foreground">What winners did:</strong> Cara Ellis built something no one had seen before (web-based generative poetry with handwriting). Johannes Specht solved a real trip-planning problem with elegant interaction. Both posts showed working prototypes and explained what was novel about their approach.</div>
            </div>
          </div>
          <div class="rounded-xl border border-border p-5 bg-card text-sm">
            <div class="font-semibold mb-3">Mar 2026</div>
            <div class="space-y-2 text-muted-foreground">
              <div><strong class="text-foreground">Criteria:</strong> Craft, originality, interaction design, audience fit</div>
              <div><strong class="text-foreground">What winners did:</strong> Charlota Blunárová's Common Thread and Lee Black's Airwwave both had exceptional craft AND community appeal. Kiel Cole's Tokyo, Dann Petty's Reframe It, and others won in specific categories they clearly wrote to. Category alignment was explicit in their posts.</div>
            </div>
          </div>
          <div class="rounded-xl border border-border p-5 bg-card text-sm">
            <div class="font-semibold mb-3">Config 2026</div>
            <div class="space-y-2 text-muted-foreground">
              <div><strong class="text-foreground">New categories added:</strong> Build In Public, Innovative Workflow, Community Favorite</div>
              <div><strong class="text-foreground">What winners did:</strong> Halle Clark (Still Here) won Build In Public with the fewest likes of any winner (8). She documented her process publicly across platforms. Bene Brandhofer won the grand prize with 23 likes. Likes did not decide Config 2026. Criteria fit did.</div>
            </div>
          </div>
        </div>

        <div class="rounded-xl border border-border p-5 bg-card">
          <div class="text-sm font-semibold mb-3">The one thing the criteria consistently rewarded</div>
          <p class="text-sm text-muted-foreground leading-relaxed">
            Every edition rewarded posts that clearly demonstrated a working interaction, explained what was novel about the approach,
            and showed that the creator understood what the contest was asking for.
            Winners who had high engagement also tended to have posts that were clear, shareable, and community-forward.
            Winners who had low engagement (like Halle Clark and Bene Brandhofer) were category-specific and criteria-precise.
            The through line: <strong class="text-foreground">match your submission to the specific category you are entering,
            not just to the general idea of the contest.</strong>
          </p>
        </div>
      </div>

      <!-- ADDITIONAL -->
      <div>
        <div class="mb-8">
          <h2 class="text-xl font-bold">Additional Charts</h2>
          <p class="text-muted-foreground mt-1">Supplementary comparisons for deeper exploration.</p>
        </div>
        <div class="space-y-8">
          <div class="rounded-xl border border-border p-6 bg-card">
            <h3 class="text-sm font-semibold mb-1">Median Metrics: Winners vs Non-Winners</h3>
            <p class="text-xs text-muted-foreground mb-4">Median values for posting day, engagement score, and social platform count.</p>
            <ComparisonBoxplots client:load />
          </div>
        </div>
      </div>

    </div>
  </section>
</Layout>
