---
import Layout from "../layouts/Layout.astro";
---

<Layout title="Home">
  <section class="mx-auto max-w-4xl px-6 py-20">
    <h1 class="text-4xl font-bold tracking-tight leading-tight mb-6">
      Figma <span class="text-[var(--color-accent)]">x</span> Contra Makeathon Analysis
    </h1>
    <p class="text-lg text-[var(--color-text-dim)] max-w-2xl leading-relaxed mb-8">
      A data-backed investigation into what separates makeathon winners from everyone else.
      We scraped, analyzed, and visualized data across three editions to answer one question:
      is early posting the dominant variable?
    </p>
    <div class="flex gap-4">
      <a href="/report" class="inline-flex items-center px-5 py-2.5 rounded-lg bg-[var(--color-accent)] text-white text-sm font-medium hover:bg-[var(--color-accent-dim)] transition-colors">
        Read the Report
      </a>
      <a href="/charts" class="inline-flex items-center px-5 py-2.5 rounded-lg border border-[var(--color-border)] text-[var(--color-text)] text-sm font-medium hover:border-[var(--color-accent)] transition-colors">
        Explore Charts
      </a>
    </div>
  </section>

  <section class="mx-auto max-w-4xl px-6 pb-20">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-16">
      <div class="rounded-xl border border-[var(--color-border)] p-6 bg-[var(--color-surface)]">
        <div class="text-3xl font-bold text-[var(--color-accent)] mb-2">318</div>
        <div class="text-sm text-[var(--color-text-dim)]">Total Entries Analyzed</div>
      </div>
      <div class="rounded-xl border border-[var(--color-border)] p-6 bg-[var(--color-surface)]">
        <div class="text-3xl font-bold text-[var(--color-accent)] mb-2">3</div>
        <div class="text-sm text-[var(--color-text-dim)]">Makeathon Editions</div>
      </div>
      <div class="rounded-xl border border-[var(--color-border)] p-6 bg-[var(--color-surface)]">
        <div class="text-3xl font-bold text-[var(--color-accent)] mb-2">23</div>
        <div class="text-sm text-[var(--color-text-dim)]">Winners Identified</div>
      </div>
    </div>

    <h2 class="text-2xl font-semibold mb-6">Key Findings</h2>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
      <div class="rounded-xl border border-[var(--color-border)] p-6 bg-[var(--color-surface)]">
        <h3 class="font-medium mb-2">Early Posters Win More</h3>
        <p class="text-sm text-[var(--color-text-dim)] leading-relaxed">
          Winners posted on average <strong class="text-[var(--color-text)]">Day 4.4</strong> of the submission window,
          compared to <strong class="text-[var(--color-text)]">Day 11.7</strong> for non-winners. A 7.3 day advantage.
        </p>
      </div>
      <div class="rounded-xl border border-[var(--color-border)] p-6 bg-[var(--color-surface)]">
        <h3 class="font-medium mb-2">Engagement Gap is Massive</h3>
        <p class="text-sm text-[var(--color-text-dim)] leading-relaxed">
          Winners averaged <strong class="text-[var(--color-text)]">8.7x</strong> more engagement
          (likes + comments x2) than non-winners.
        </p>
      </div>
      <div class="rounded-xl border border-[var(--color-border)] p-6 bg-[var(--color-surface)]">
        <h3 class="font-medium mb-2">Cross-Platform Presence Matters</h3>
        <p class="text-sm text-[var(--color-text-dim)] leading-relaxed">
          Winners cross-posted to <strong class="text-[var(--color-text)]">3.0 platforms</strong> on average
          vs <strong class="text-[var(--color-text)]">1.1</strong> for non-winners.
        </p>
      </div>
      <div class="rounded-xl border border-[var(--color-border)] p-6 bg-[var(--color-surface)]">
        <h3 class="font-medium mb-2">No Pre-Challenge Advantage Found</h3>
        <p class="text-sm text-[var(--color-text-dim)] leading-relaxed">
          Video upload date analysis found <strong class="text-[var(--color-text)]">zero evidence</strong> of
          winners starting before their challenge began. The advantage is early submissions within the window.
        </p>
      </div>
    </div>
  </section>
</Layout>
