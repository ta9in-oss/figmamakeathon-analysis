---
import "../styles/global.css";

interface Props {
  title: string;
  description?: string;
}

const { title, description } = Astro.props;
---

<!doctype html>
<html lang="en" dir="ltr">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="description" content={description || "Figma x Contra Makeathon Analysis — Data-backed insights on what separates winners from everyone else."} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title} — Figma Makeathon Analysis</title>
  </head>
  <body class="min-h-screen">
    <nav class="fixed top-0 left-0 right-0 z-50 border-b border-border-border bg-bg-background/90 backdrop-blur-sm fade-in">
      <div class="mx-auto max-w-4xl px-6 py-3 flex items-center justify-between">
        <a href="/" class="flex items-center gap-3 text-sm font-semibold tracking-tight text-text-foreground hover:text-text-primary transition-colors">
          <svg width="18" height="18" viewBox="0 0 38 57" fill="none" xmlns="http://www.w3.org/2000/svg" aria-label="Figma">
            <path d="M19 28.5C19 25.981 21.011 24 23.5 24C25.989 24 28 25.981 28 28.5C28 31.0193 25.989 33 23.5 33C21.011 33 19 31.0193 19 28.5Z" fill="#1ABCFE"/><path d="M10 37.5C10 35.015 12.011 33 14.5 33H19V37.5C19 39.985 16.989 42 14.5 42C12.011 42 10 39.985 10 37.5Z" fill="#0ACF83"/><path d="M19 10V19H23.5C25.989 19 28 17.015 28 14.5C28 11.985 25.989 10 23.5 10H19Z" fill="#FF7262"/><path d="M10 14.5C10 16.985 12.011 19 14.5 19H19V10H14.5C12.011 10 10 11.985 10 14.5Z" fill="#F24E1E"/><path d="M10 28.5C10 31.015 12.011 33 14.5 33H19V24H14.5C12.011 24 10 25.981 10 28.5Z" fill="#A259FF"/>
          </svg>
          <svg width="16" height="16" viewBox="0 0 137 137" fill="none" xmlns="http://www.w3.org/2000/svg" aria-label="Contra">
            <path fill-rule="evenodd" clip-rule="evenodd" d="M48.4548 23.4063C41.8837 33.4272 33.2818 41.999 23.2133 48.54C16.1031 53.4013 8.30854 57.355 0 60.2156V62.5096H62.477V0H60.2783C57.4001 8.37623 53.3963 16.241 48.4523 23.4063H48.4548ZM73.8242 0V62.7779H136.309V60.4839C128.003 57.6233 120.213 53.6696 113.095 48.8083C103.037 42.2673 94.4276 33.6955 87.8565 23.6746C82.8598 16.4341 78.8234 8.47902 75.9377 0H73.8242ZM136.309 73.5283H73.8242V136.306H75.9377C78.8234 127.83 82.8573 119.872 87.8565 112.632C94.4276 102.611 103.039 94.039 113.095 87.4979C120.213 82.6341 128.003 78.6829 136.309 75.8223V73.5283ZM62.4795 136.306V73.7966H0.0025071V76.0906C8.30854 78.9512 16.1056 82.9049 23.2158 87.7662C33.2818 94.3072 41.8837 102.882 48.4573 112.9C53.4013 120.065 57.4027 127.927 60.2833 136.304H62.482L62.4795 136.306Z" fill="currentColor"/>
          </svg>
          <span>Makeathon Analysis</span>
        </a>
        <div class="flex gap-6 text-sm font-medium">
          <a href="/report" class="text-text-muted-foreground hover:text-text-foreground transition-colors">Report</a>
          <a href="/charts" class="text-text-muted-foreground hover:text-text-foreground transition-colors">Charts</a>
          <a href="/data" class="text-text-muted-foreground hover:text-text-foreground transition-colors">Data</a>
          <a href="/video-analysis" class="text-text-muted-foreground hover:text-text-foreground transition-colors">Videos</a>
        </div>
      </div>
    </nav>
    <main class="pt-16">
      <slot />
    </main>
    <footer class="border-t border-border-border mt-16 py-10">
      <div class="mx-auto max-w-4xl px-6 text-sm text-text-muted-foreground/70">
        <p class="flex items-center gap-2">
          <span>Made with</span>
          <svg width="14" height="14" viewBox="0 0 24 24" fill="#ef4444" xmlns="http://www.w3.org/2000/svg" aria-label="heart">
            <path d="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35z"/>
          </svg>
          <span>by</span>
          <a href="https://ta9in.com" class="font-medium text-text-muted-foreground hover:text-text-primary transition-colors">ta9in</a>
        </p>
        <p class="mt-2">
          <a href="https://github.com/ta9in-oss/figmamakeathon-analysis" class="text-text-muted-foreground hover:text-text-primary transition-colors">GitHub</a>
          <span class="mx-2">&middot;</span>
          <a href="/data" class="text-text-muted-foreground hover:text-text-primary transition-colors">Raw Data</a>
        </p>
      </div>
    </footer>
  </body>
</html>

<style>
  html, body {
    margin: 0;
    width: 100%;
    height: 100%;
  }
</style>
